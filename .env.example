# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el .env real a GitHub.

# URL base de tu instancia Jira (sin barra final)
JIRA_URL=https://tu-instancia.atlassian.net

# Email de la cuenta Jira
JIRA_EMAIL=tu.email@empresa.com

# API Token generado en: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=tu_api_token_aqui
